# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules

# auto-generated from postinstall
/public/axe-core
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem

# embedded dev database (PGlite fallback when DATABASE_URL is unset)
/.dev-db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but the template (no secrets) IS tracked, so it documents required vars + feature flags
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# design tool reference exports
/design_handoff_a11y_beast
