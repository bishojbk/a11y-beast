# Required for AI-powered fix generation
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Paid-feature gates (default OFF) ───────────────────────────────
# Both are Pro features with real per-request cost. They are disabled
# until an entitlement/billing check sits in front of them, otherwise
# the public endpoints can be abused (unbounded Anthropic bill / free
# site-wide crawl). Set to "true" ONLY behind auth.

# Enables POST /api/v1/fix (Anthropic-backed AI fixes). Also needs ANTHROPIC_API_KEY.
ENABLE_AI_FIX=

# Dev/self-host override for POST /api/v1/crawl. In normal operation the
# entitlement is the signed-in user's plan (pro/agency); this flag force-opens
# the endpoint without accounts. Leave unset in production.
ENABLE_SITE_CRAWL=

# ── Accounts / database ─────────────────────────────────────────────
# Postgres connection string (Neon via Vercel Marketplace, or any Postgres).
# Unset in dev = automatic embedded PGlite store in .dev-db/ (zero setup).
# Apply schema with: DATABASE_URL=... node scripts/db-migrate.mjs
DATABASE_URL=

# ── Stripe billing ───────────────────────────────────────────────────
# Until ALL of these are set, paid tiers stay in waitlist mode (checkout
# routes return 503 and the pricing page shows waitlist CTAs).
# Setup: create three recurring prices in the Stripe dashboard —
#   Pro monthly  $19/mo   → STRIPE_PRICE_PRO_MONTHLY
#   Pro annual   $190/yr  → STRIPE_PRICE_PRO_ANNUAL
#   Agency founding $99/mo → STRIPE_PRICE_AGENCY_FOUNDING
# Webhook endpoint: /api/v1/billing/webhook — subscribe to
# checkout.session.completed + customer.subscription.{created,updated,deleted}
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_AGENCY_FOUNDING=

# Absolute site origin used in Stripe redirect URLs (falls back to request host)
SITE_URL=
